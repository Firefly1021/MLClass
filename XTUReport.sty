\newcommand{\vecb}[1]{\bm{#1}}
%中文摘要环境
\newenvironment{abstractcn}[1][摘要]{
  \par % 新段落
  \begin{center}
    \bfseries \zihao{4} #1 \par % 标题样式（加粗、四号字）
  \end{center}
  \vspace{0.5em} % 标题与内容间距
  \setlength{\parindent}{2em}
  \normalsize \mdseries % 内容恢复常规字号、不加粗
  \begin{spacing}{1.2} % 摘要内容行间距1.2倍
}{
  % 环境结束时的操作：关闭行间距设置
  \end{spacing}
}

%英文摘要环境
\newenvironment{abstracten}[1][Abstract]{
  \par
  \begin{center}
    \bfseries \fontsize{14}{16}\selectfont #1 \par % 英文标题字号
  \end{center}
  \vspace{0.5em}
  \setlength{\parindent}{2em}
  \normalsize \mdseries
  \begin{spacing}{1.2}
}{%
  \end{spacing}
}

